# ─── Resume Studio — environment configuration ───────────────────────────────
# Copy this file to .env and fill in the values.

# API authentication token.
# Required when deploying to a VPS (accessible from the internet).
# Leave empty for local development — auth is disabled when this is unset.
# Generate a strong token: openssl rand -hex 32
RESUME_API_TOKEN=

# HTTP port the server listens on.
# Default: 3001
PORT=3001

# ─── API rate limiting (optional) ────────────────────────────────────────────
# The auth-gated API has a failure-focused rate limiter: only responses with
# status >= 400 count against the window, so it brakes bearer-token brute-force
# and bad-request floods WITHOUT throttling a consultant's legitimate auto-save
# traffic (a steady stream of 2xx PUTs). Defaults are usually fine; tune for a
# more- or less-exposed deployment.
# Max counted failures per window per IP. Default: 50
RESUME_RATE_LIMIT_MAX=50
# Window length in milliseconds. Default: 900000 (15 minutes)
RESUME_RATE_LIMIT_WINDOW_MS=900000

# ─── Translation assist (optional, self-hosted) ──────────────────────────────
# Base URL of a self-hosted LibreTranslate instance. When set, the editor shows
# a "Draft translation" button on the secondary-language input that proxies
# through this server (CV text never leaves your deployment). Leave empty to
# disable — the "Copy from primary" button works regardless.
# Easiest: run the bundled service with `npm run dev:translate` (Docker), then
# set this to http://localhost:5000 and restart the server. See docker-compose.yml.
# Keep it empty unless the service is actually running, or the Draft button will
# appear but every request will fail with "unreachable".
LIBRETRANSLATE_URL=

# Optional API key, if your LibreTranslate instance requires one.
LIBRETRANSLATE_API_KEY=
